{
  "protocolName": "pokeemerald-rebuild-v2",
  "wireFormat": "versioned-json-placeholder",
  "version": 1,
  "messages": {
    "server_hello": {
      "type": "server_hello",
      "protocolVersion": "u16",
      "serverAuthority": "bool",
      "clientVersionEcho": "string",
      "assetManifest": {
        "assetBaseUrl": "string",
        "assetVersion": "string",
        "tilesetPairId": "string",
        "atlasUrl": "string?",
        "palettesUrl": "string?",
        "metatilesUrl": "string?"
      }
    },
    "render_state_v1": {
      "type": "render_state_v1",
      "protocolVersion": "u16",
      "mapId": "string",
      "tilesetPairId": "string",
      "camera": {
        "runtimeX": "i32",
        "runtimeY": "i32"
      },
      "scroll": {
        "xPixelOffset": "i32",
        "yPixelOffset": "i32",
        "horizontalPan": "i32",
        "verticalPan": "i32"
      },
      "playerRenderProxy": {
        "mapLocalX": "i32",
        "mapLocalY": "i32",
        "subpixelX": "i32",
        "subpixelY": "i32",
        "cameraPosX": "i32",
        "cameraPosY": "i32",
        "xTileOffset": "i32",
        "yTileOffset": "i32"
      },
      "window": {
        "originRuntimeX": "i32",
        "originRuntimeY": "i32",
        "width": 16,
        "height": 16
      },
      "metatiles": [
        {
          "packedRaw": "u16",
          "metatileId": "u16",
          "collision": "u8",
          "elevation": "u8",
          "layerType": "u8",
          "subtiles": [
            {
              "subtileIndex": "u8",
              "tileIndex": "u16",
              "paletteIndex": "u8",
              "hflip": "bool",
              "vflip": "bool",
              "layer": "u8",
              "layerOrder": "u8"
            }
          ]
        }
      ]
    }
  }
}
